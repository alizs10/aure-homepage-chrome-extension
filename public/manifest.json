{
    "manifest_version": 3,
    "name": "Aure Homepage",
    "version": "0.0.1",
    "description": "Custom New Tab",
    "permissions": [
        "storage",
        "topSites"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "host_permissions": [
        "<all_urls>"
    ],
    "chrome_url_overrides": {
        "newtab": "index.html"
    },
    "icons": {
        "16": "icon-16.png",
        "32": "icon-32.png",
        "48": "icon-48.png",
        "128": "icon-128.png"
    }
}